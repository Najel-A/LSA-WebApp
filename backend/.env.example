# Server
PORT=3000
# Use IPv6 any-address so localhost (::1) works in dev.
# In Docker, set HOST=0.0.0.0 explicitly.
HOST=::

# MongoDB connection string (required)
# Local: mongodb://localhost:27017/lsa-webapp
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/lsa-webapp
MONGODB_URI=mongodb://localhost:27017/lsa-webapp

# JWT (required for auth). Use a strong random secret in production, e.g. openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-in-production

# Optional: token lifetime (default 15m). Examples: 15m, 1h, 900
# JWT_EXPIRES_IN=15m

# Optional: CORS origin for frontend (default: http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Alerts ingestion (API-key for POST /api/alerts/ingest)
# Provide this in production via secret manager / env vars.
# Clients may send it as X-API-Key: <key> or Authorization: Bearer <key>
# ALERT_INGEST_API_KEY=change-me
