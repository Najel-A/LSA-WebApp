# Copy to .env in this directory (optional). Docker Compose reads .env automatically for variable substitution.
# You do NOT need to run npm install on the host — images install deps with npm ci inside Docker.

# --- Registry / tags (optional; for docker compose push) ---
# IMAGE_TAG=2026-05-03
# BACKEND_IMAGE=your-registry.example.com/lsa-webapp-backend
# FRONTEND_IMAGE=your-registry.example.com/lsa-webapp-frontend
# ANALYZER_IMAGE=your-registry.example.com/lsa-webapp-analyzer

# --- Port bindings (host:container left side) ---
# Default: Mongo and analyzer only on localhost; backend/frontend on all interfaces.
# MONGO_BIND=127.0.0.1:27017
# ANALYZER_BIND=127.0.0.1:8000
# BACKEND_BIND=0.0.0.0:3000
# FRONTEND_BIND=0.0.0.0:8080

# --- Backend ---
# Local default uses the mongo service name. For Atlas / managed DB, set full URI:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/lsa-webapp
JWT_SECRET=change-me-in-production
# Public browser origin of your SPA (nginx URL). Cloud example:
# CORS_ORIGIN=https://app.yourdomain.com
CORS_ORIGIN=http://localhost:8080
# ALERT_INGEST_API_KEY=

# --- Frontend build args (used at docker compose build time) ---
# VITE_API_BASE_URL=
# VITE_NEXUSTRACE_ANALYZE_URL=/query
# VITE_NEXUSTRACE_ANALYZE_TIMEOUT_MS=600000

# --- NexusTrace analyzer (fastapi/) — unset *_URL = stub agents (still runs full pipeline) ---
# MODEL_TIMEOUT_S=180
# Ollama on host (Docker Desktop / Linux with host-gateway). Example:
# RCA_QWEN_URL=http://host.docker.internal:11434
# RCA_QWEN_MODEL=qwen2.5:7b
# RCA_DEEPSEEK_URL=http://host.docker.internal:11434
# RCA_DEEPSEEK_MODEL=deepseek-r1:7b
# EXECUTOR_URL=http://host.docker.internal:11434
# EXECUTOR_MODEL=mistral:7b
# VALIDATOR_URL=http://host.docker.internal:11434
# VALIDATOR_MODEL=llama3.2:3b

# --- Option: run the provided LoRA model images in Compose (profile: models) ---
# These containers expose POST /v1/rca/generate and require mounted adapter folders.
# 1) Put your LoRA adapter files here (must include adapter_config.json):
#    fastapi/adapters/qwen/
#    fastapi/adapters/deepseek/
#    fastapi/adapters/executor-mistral/
#    fastapi/adapters/validator-llama/
# 2) Start the stack with models:
#    docker compose --profile models up -d
# 3) Point the analyzer at the in-network services:
# RCA_QWEN_URL=http://rca-qwen:8000
# RCA_DEEPSEEK_URL=http://rca-deepseek:8000
# EXECUTOR_URL=http://executor-mistral:8000
# VALIDATOR_URL=http://validator-llama:8000
